# .env.example — reference for all environment variables.
# Copy to .env.local (consuming sites) / set in the Vercel project (the API).
# NEVER commit real secrets; .env* files are gitignored.

# ─────────────────────────────────────────────────────────────────────────────
# SERVERLESS API (set on the Vercel project that hosts this repo) — SERVER-ONLY
# ─────────────────────────────────────────────────────────────────────────────

# Neon pooled connection string. Required.
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Salts the SHA-256 IP hash. REQUIRED — if unset, the API refuses to start
# hashing rather than silently producing weak, unsalted hashes.
# Generate: openssl rand -hex 32
IP_SALT=

# Server-only secret gating the GDPR deletion endpoint (sent as x-admin-token).
# REQUIRED for /api/consent-deletion. NEVER prefix with NEXT_PUBLIC_.
# Generate: openssl rand -hex 32
CONSENT_ADMIN_TOKEN=

# Upstash Redis — enables distributed rate limiting. Recommended in production.
# Without these the limiter degrades to a per-instance in-memory limiter.
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Set to "true" in production so a missing/typo'd Redis config logs a loud
# [RATELIMIT_MISCONFIGURED] warning instead of silently degrading.
REQUIRE_RATE_LIMIT=

# Axiom — optional operational logging. Skipped entirely if unset.
AXIOM_TOKEN=
AXIOM_DATASET=

# ─────────────────────────────────────────────────────────────────────────────
# CONSUMING SITES (.env.local) — these ship to the BROWSER (NEXT_PUBLIC_*)
# ─────────────────────────────────────────────────────────────────────────────

# Where the client POSTs consent events.
NEXT_PUBLIC_CONSENT_API=https://your-consent-api.vercel.app/api/consent

# Coarse domain key (NOT a secret — it is public). Must match the `token`
# value registered for this domain in the site_tokens table.
NEXT_PUBLIC_SITE_CONSENT_TOKEN=your-site-domain-key

# Analytics (optional — omit if unused).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=your-cf-token

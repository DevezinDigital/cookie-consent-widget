{
  "name": "@devezindigital/cookie-consent",
  "version": "1.0.0",
  "description": "GDPR/CCPA-compliant cookie consent system with centralized logging for multi-site deployment",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.esm.js",
      "require": "./dist/constants.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "templates"
  ],
  "bin": {
    "cookie-consent-init": "./bin/index.js"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=19"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@neondatabase/serverless": "^1.0.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@upstash/redis": "^1.38.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "lucide-react": "^1.25.0",
    "prettier": "^3.9.6",
    "rollup": "^4.62.2",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "tslib": "^2.8.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "cookie-consent",
    "gdpr",
    "ccpa",
    "react",
    "privacy",
    "analytics",
    "compliance"
  ],
  "author": "Devezin Digital",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/DevezinDigital/cookie-consent-widget.git"
  }
}
